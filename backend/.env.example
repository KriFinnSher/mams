# Build
BINARY_NAME=mams
BUILD_DIR=bin

# Go
GO=go
GOFLAGS=-v -ldflags="-s -w"

# Docker
DOCKER=docker
DOCKER_COMPOSE=docker-compose

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=mams
DB_PASSWORD=mams
DB_NAME=mams

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=mams_logs

# App
APP_HOST=0.0.0.0
APP_PORT=8080

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Kubernetes
KUBERNETES_CONFIG_PATH=~/.kube/config

# GitHub
GITHUB_TOKEN=

# Prometheus
PROMETHEUS_URL=http://localhost:9090
